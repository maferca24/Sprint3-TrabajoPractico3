<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Editar Superhéroe</title>
</head>
<body>
    <h1>Editar Superhéroe: <%= heroe.nombreSuperHeroe %></h1>
    
    <form id="editForm">
        <label>Nombre del Superhéroe:</label>   
        <input type="text" id="nombreSuperHeroe" value="<%= heroe.nombreSuperHeroe %>" required><br>

        <label>Nombre Real:</label>
        <input type="text" id="nombreReal" value="<%= heroe.nombreReal %>" required><br>

        <label>Edad:</label>
        <input type="number" id="edad" value="<%= heroe.edad %>"><br>

        <label>Planeta de Origen:</label>
        <input type="text" id="planetaOrigen" value="<%= heroe.planetaOrigen %>"><br>

        <label>Poderes (separados por coma):</label>
        <input type="text" id="poderes" value="<%= heroe.poderes ? heroe.poderes.join(', ') : '' %>"><br>

        <label>Aliados:</label>
        <input type="text" id="aliados" value="<%= heroe.aliados ? heroe.aliados.join(', ') : '' %>"><br>       
                
        <label>Enemigos:</label>
        <input type="text" id="enemigos" value="<%= heroe.enemigos ? heroe.enemigos.join(', ') : '' %>"><br>

        <label>Creador:</label>
        <input type="text" id="creador" value="<%= heroe.creador %>"><br>

        <button type="submit">Actualizar</button>
        <a href="/dashboard">Cancelar</a>
    </form>

    <script>
        document.getElementById("editForm")
        .addEventListener('submit', async(e) => {   
            e.preventDefault
            const bodyData = {
                nombreSuperHeroe: form.nombreSuperHeroe.value.trim(),
                nombreReal: form.nombreReal.value.trim(),
                edad: parseInt(form.edad.value) || 0,
                planetaOrigen: form.planetaOrigen.value.trim(),
                poderes: form.poderes.value.split(',').map(p => p.trim()).filter(p => p !== ''),
                aliados: form.aliados.value.split(',').map(p => p.trim()).filter(p => p !== ''),
                enemigos: form.enemigos.value.split(',').map(p => p.trim()).filter(p => p !== ''),
                creador: form.creador.value.trim()      

            };

            try {
                const response = await fetch(`http://localhost:3000/api/heroes/${'<%= heroe._id %>' || '<%= heroe.id %>'}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(bodyData)
                });

                if (response.ok) {
                    alert("Superhéroe actualizado correctamente.");
                    window.location.href = "/dashboard";
                } else {
                    const errorData = await response.json();
                    alert("Error al actualizar: " + (errorData.mensaje || "Error desconocido"));
                }
            } catch (error) {
                console.error("Error de red:", error);
                alert("No se pudo conectar con el servidor.");
            }

        });
    </script>
</body> 
</html>


        




                