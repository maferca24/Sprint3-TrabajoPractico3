<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <title>Editar Superhéroe</title>
</head>

<body>
    <h1>Editar Superhéroe: <%= heroe.Nombre %></h1>

    <form id="editForm">
        <label>Nombre del Superhéroe:</label>
        <input type="text" id="nombreSuperHeroe" value="<%= heroe.Nombre %>" required><br>

        <label>Nombre Real:</label>
        <input type="text" id="nombreReal" value="<%= heroe['Nombre Real'] %>" required><br>

        <label>Edad:</label>
        <input type="number" id="edad" value="<%= heroe.Edad %>"><br>

        <label>Planeta de Origen:</label>
        <input type="text" id="planetaOrigen" value="<%= heroe['Planeta de Origen'] %>"><br>

        <label>Poderes:</label>
        <input type="text" id="poderes" value="<%= heroe.Poderes ? heroe.Poderes.join(', ') : '' %>"><br>

        <label>Aliados:</label>
        <input type="text" id="aliados" value="<%= heroe.Aliados ? heroe.Aliados.join(', ') : '' %>"><br>

        <label>Enemigos:</label>
        <input type="text" id="enemigos" value="<%= heroe.Enemigos ? heroe.Enemigos.join(', ') : '' %>"><br>

        <label>Creador:</label>
        <input type="text" id="creador" value="<%= heroe.creador || '' %>"><br>

        <button type="submit">Actualizar</button>
        <a href="/dashboard">Cancelar</a>
    </form>

    <script>
        document.getElementById("editForm").addEventListener('submit', async (e) => {
            e.preventDefault();

            // 1. Obtenemos el ID del héroe desde EJS
            const idHeroe = "<%= heroe._id %>";
            
            // 2. Mapeamos los datos con los nombres EXACTOS de tu base de datos
            const bodyData = {
                "Nombre": document.getElementById("nombreSuperHeroe").value.trim(),
                "Nombre Real": document.getElementById("nombreReal").value.trim(),
                "Edad": parseInt(document.getElementById("edad").value) || 0,
                "Planeta de Origen": document.getElementById("planetaOrigen").value.trim(),
                "Poderes": document.getElementById("poderes").value.split(',').map(p => p.trim()).filter(p => p !== ''),
                "Aliados": document.getElementById("aliados").value.split(',').map(p => p.trim()).filter(p => p !== ''),
                "Enemigos": document.getElementById("enemigos").value.split(',').map(p => p.trim()).filter(p => p !== ''),
                "creador": document.getElementById("creador").value.trim()
            };

            // 3. Construimos la URL (asegúrate que tu ruta en el backend sea /api/heroes/id/:id)
            const url = `http://localhost:3000/api/heroes/id/${idHeroe}`;

            console.log("Intentando actualizar en:", url);

            try {
                const response = await fetch(url, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(bodyData)
                });

                if (response.ok) {
                    alert('¡Actualizado con éxito!');
                    window.location.href = '/dashboard';
                } else {
                    const errorDetail = await response.json();
                    console.error('Error del servidor:', errorDetail);
                    alert('Error al actualizar: ' + (errorDetail.message || 'Error desconocido'));
                }
            } catch (err) {
                console.error('Error de red:', err);
                alert('No se pudo conectar con el servidor.');
            }
        });
    </script>
</body>
</html>