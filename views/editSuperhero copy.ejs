<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Editar Superhéroe</title>
</head>
<body>
    <h1>Editar Superhéroe: <%= heroe.nombreSuperHeroe %></h1>
    
    <form id="editForm">
        <label>Nombre del Superhéroe:</label>   
        <input type="text" id="nombreSuperHeroe" value="<%= heroe.nombreSuperHeroe %>" required><br>

        <label>Nombre Real:</label>
        <input type="text" id="nombreReal" value="<%= heroe.nombreReal %>" required><br>

        <label>Edad:</label>
        <input type="number" id="edad" value="<%= heroe.edad %>"><br>

        <label>Planeta de Origen:</label>
        <input type="text" id="planetaOrigen" value="<%= heroe.planetaOrigen %>"><br>

        <label>Poderes (separados por coma):</label>
        <input type="text" id="poderes" value="<%= heroe.poderes ? heroe.poderes.join(', ') : '' %>"><br>

        <label>Aliados:</label>
        <input type="text" id="aliados" value="<%= heroe.aliados ? heroe.aliados.join(', ') : '' %>"><br>       
                
        <label>Enemigos:</label>
        <input type="text" id="enemigos" value="<%= heroe.enemigos ? heroe.enemigos.join(', ') : '' %>"><br>

        <label>Creador:</label>
        <input type="text" id="creador" value="<%= heroe.creador %>"><br>

        <button type="submit">Actualizar</button>
        <a href="/dashboard">Cancelar</a>
    </form>

    <script>
        document.getElementById("editForm")
        .addEventListener('submit', async function (event) {
            event.preventDefault();

            // 1. Capturamos TODOS los campos 
            const bodyData = {
                nombreSuperHeroe: document.getElementById('nombreSuperHeroe').value.trim(),
                nombreReal: document.getElementById('nombreReal').value.trim(),
                edad: parseInt(document.getElementById('edad').value) || 0,
                planetaOrigen: document.getElementById('planetaOrigen').value.trim(),
                poderes: document.getElementById('poderes').value.split(',').map(p => p.trim()).filter(p => p !== ''),
                aliados: document.getElementById('aliados').value.split(',').map(p => p.trim()).filter(p => p !== ''),
                enemigos: document.getElementById('enemigos').value.split(',').map(p => p.trim()).filter(p => p !== ''),
                creador: document.getElementById('creador').value.trim()
            };

            try {

                // 2. Usamos bodyData en el JSON.stringify
                //const response = await fetch('/api/heroes/<%= heroe._id %>', { 
                const response = await fetch(`http://localhost:3000/api/heroes/${'<%= heroe._id %>' || '<%= heroe.id %>'}`, { 

                    method: 'PUT', 
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(bodyData)
                });

                if (response.ok) {
                    alert('¡Actualizado con éxito!');
                    window.location.href = '/dashboard';
                } else {
                    const errorDetail = await response.json();
                    console.error('Error del servidor:', errorDetail);
                    alert('Error al actualizar: ' + (errorDetail.message || 'Error desconocido'));
                }
            } catch (err) {
                console.error('Error de red:', err);
                alert('Error de conexión con el servidor');
            }
        }); // <-- Aquí faltaba cerrar correctamente la función
    </script>
</body>
</html>